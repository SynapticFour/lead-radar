# Optional: higher GitHub Search API rate limits
GITHUB_TOKEN=

# Reddit script app (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Optional: Claude Haiku triage pass on digest items
ANTHROPIC_API_KEY=

# Optional: Slack or Discord webhook for top-5 alerts
WEBHOOK_URL=

# Shown in User-Agent header on all requests
CONTACT_EMAIL=you@yourdomain.com
